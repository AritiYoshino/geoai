          "variants": ["餐饮", "购物", "医疗", "生活服务"],
          "repeat": 5,
          "expected_tools": ["summarize_layer_statistics"],
          "expected_outputs": {"has_map_layer": false, "has_table": true, "min_result_count": 1},
          "difficulty": "medium",
          "failure_mode": "field_name_mismatch"
        }
