        {"id": "cl_{n}", "category": "hotspot", "query": "第3批：生成 {v} POI 热点网格", "variants": ["餐饮", "购物", "医疗", "公司"], "repeat": 5, "expected_tools": ["hotspot_analysis"], "expected_outputs": {"has_map_layer": true, "has_table": true, "min_result_count": 1}, "difficulty": "hard"},
