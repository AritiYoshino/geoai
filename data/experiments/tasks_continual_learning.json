          "difficulty": "medium",
          "failure_mode": "crs_distance"
        },
        {
          "id": "cl_{n}",
          "category": "attribute_query",
          "query": "第1批：先核对字段，再查询 {v} 图层中的指定类型 POI",
          "variants": ["餐饮", "购物", "生活服务", "住宿服务"],
          "repeat": 5,
          "expected_tools": ["query_poi_by_conditions"],
