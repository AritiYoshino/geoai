{
  "id": "exp2_workbook_evolution_v2",
  "name": "实验二：Online Adaptation 在线适应实验",
  "description": "三批连续在线适应任务，题量扩展到 90 题。Batch 1 验证 RAG/ACE 共享静态经验库相对 BASE 的优势；Batch 2 投放静态 RAG 库没有的新错误模式，只有 ACE 能通过 Evolution 写入并立即迁移；Batch 3 主要复测新增经验，验证 ACE 随批次提升而 RAG/BASE 不随最终小测同步上涨。",
  "repeat_multiplier": 1,
  "batches": [
    {
      "batch_id": 1,
      "theme": "静态经验收益：RAG 与 ACE 共享初始经验库，BASE 无经验",
      "tasks": [
        {
          "id": "exp2_b1_easy_search",
          "category": "poi_search",
          "query": "搜索名称包含“{keyword}”的{layer} POI，返回地图图层和结果表。",
          "difficulty": "easy",
          "capabilities": ["tool_search"],
          "variants": [
            {"id": "hotpot_food", "keyword": "火锅", "layer": "餐饮"},
            {"id": "tea_food", "keyword": "茶饮", "layer": "餐饮"},
            {"id": "bank_finance", "keyword": "银行", "layer": "金融服务"},
            {"id": "hotel_stay", "keyword": "酒店", "layer": "住宿服务"}
          ]
        },
        {
          "id": "exp2_b1_known_crs",
          "category": "nearby_analysis",
          "query": "复用 CRS 距离经验，查找{anchor} {distance}米内的{target} POI。",
          "difficulty": "medium",
          "capabilities": ["nearby_analysis", "experience_retrieval"],
          "failure_mode": "crs_distance",
          "variants": [
            {"id": "school_food_500", "anchor": "学校", "distance": "500", "target": "餐饮"},
            {"id": "hospital_food_300", "anchor": "医院", "distance": "300", "target": "餐饮"},
            {"id": "finance_food_300", "anchor": "金融服务点", "distance": "300", "target": "餐饮"},
            {"id": "metro_hotel_600", "anchor": "交通设施", "distance": "600", "target": "住宿服务"},
            {"id": "shopping_life_400", "anchor": "购物中心", "distance": "400", "target": "生活服务"}
          ]
        },
        {
          "id": "exp2_b1_known_schema",
          "category": "attribute_query",
          "query": "复用字段核对经验，在{layer}图层中查询“{keyword}”相关 POI，并输出 schema 校验说明。",
          "difficulty": "medium",
          "capabilities": ["schema_following", "experience_retrieval"],
          "failure_mode": "field_name_mismatch",
          "variants": [
            {"id": "food_hotpot", "layer": "餐饮", "keyword": "火锅"},
            {"id": "medical_emergency", "layer": "医疗", "keyword": "急诊"},
            {"id": "life_repair", "layer": "生活服务", "keyword": "维修"},
            {"id": "education_school", "layer": "科教文化", "keyword": "学校"},
            {"id": "finance_branch", "layer": "金融服务", "keyword": "支行"}
          ]
        },
        {
          "id": "exp2_b1_known_empty",
          "category": "poi_search",
          "query": "复用空结果放宽经验，搜索“{keyword}”相关 POI，若严格检索为空则逐级放宽。",
          "difficulty": "medium",
          "capabilities": ["tool_search", "empty_result_repair", "experience_retrieval"],
          "failure_mode": "empty_result",
          "variants": [
            {"id": "child_emergency", "keyword": "24小时儿童急诊"},
            {"id": "night_pharmacy", "keyword": "夜间药房"},
            {"id": "wheelchair_hotel", "keyword": "无障碍酒店"},
            {"id": "elderly_service", "keyword": "养老照护中心"}
          ]
        }
      ]
    },
